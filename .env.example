# =============================================================================
# Environment configuration for bookstore
#
# Copy this file to .env and fill in the values before running docker-compose.
#
#   cp .env.example .env
#
# For non-local environments, use scripts/fetch-secrets.sh to populate .env
# from your secrets backend instead of editing it by hand:
#
#   SECRETS_BACKEND=ssm ENV=staging ./scripts/fetch-secrets.sh
#
# .env is git-ignored and must never be committed.
# =============================================================================


# -----------------------------------------------------------------------------
# Database connection
#
# Owner: Platform team
#
# Local docker-compose:  DB_HOST=db  (the docker-compose service name)
# Deployed environments: DB_HOST is the real RDS/Cloud SQL hostname
#
# SSM paths:
#   /development/bookstore/db-host
#   /development/bookstore/db-port
#   /development/bookstore/db-name
#
# Secrets Manager / Vault: keys db-host, db-port, db-name within
#   /development/bookstore/database
# -----------------------------------------------------------------------------
DB_HOST=CHANGE_ME
DB_PORT=CHANGE_ME
DB_NAME=CHANGE_ME


# -----------------------------------------------------------------------------
# Superuser password  (Platform team only — DBAs and CI/CD pipelines)
#
# SSM:              /development/bookstore/db-admin-password  (SecureString)
# Secrets Manager:  key db-admin-password in /development/bookstore/database
# Vault:            field db-admin-password in secret/development/bookstore/database
# -----------------------------------------------------------------------------
DB_ADMIN_PASSWORD=CHANGE_ME


# -----------------------------------------------------------------------------
# Application user password  (handoff credential: Platform team sets, bookstore
# squad reads — this is the only secret the squad needs)
#
# SSM:              /development/bookstore/app-user-password  (SecureString)
# Secrets Manager:  key app-user-password in /development/bookstore/database
# Vault:            field app-user-password in secret/development/bookstore/database
# -----------------------------------------------------------------------------
APP_USER_PASSWORD=CHANGE_ME


# -----------------------------------------------------------------------------
# Reporting user password  (Platform team only)
#
# SSM:              /development/bookstore/reporting-user-password  (SecureString)
# Secrets Manager:  key reporting-user-password in /development/bookstore/database
# Vault:            field reporting-user-password in secret/development/bookstore/database
# -----------------------------------------------------------------------------
REPORTING_USER_PASSWORD=CHANGE_ME
